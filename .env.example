# ===== APP =====
PORT=3000
NODE_ENV=production

# Mật khẩu đăng nhập vào dashboard (ĐỔI NGAY sau khi deploy!)
ADMIN_PASSWORD=change-me-now
# Secret để ký JWT token (random chuỗi dài bất kỳ)
JWT_SECRET=replace-with-random-long-string-at-least-32-chars

# ===== TIMEZONE =====
TZ=Asia/Ho_Chi_Minh

# ===== ANTHROPIC (Claude) - để tạo caption tiếng Việt =====
# Lấy tại: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ===== FAL.AI - để tạo ảnh & video =====
# Lấy tại: https://fal.ai/dashboard/keys
FAL_API_KEY=

# ===== FACEBOOK =====
# App ID & Secret lấy tại https://developers.facebook.com/apps
FB_APP_ID=
FB_APP_SECRET=
# Page Access Token của 2 Fanpage (sẽ điền ở UI Settings sau khi đăng nhập)
