# ===== APP =====
PORT=3000
NODE_ENV=production

# Mật khẩu đăng nhập vào dashboard (ĐỔI NGAY sau khi deploy!)
ADMIN_PASSWORD=change-me-now
# Secret để ký JWT token (random chuỗi dài bất kỳ)
JWT_SECRET=replace-with-random-long-string-at-least-32-chars

# ===== TIMEZONE =====
TZ=Asia/Ho_Chi_Minh

# ===== ANTHROPIC (Claude) - để tạo caption tiếng Việt =====
# Lấy tại: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ===== FAL.AI - để tạo ảnh & video =====
# Lấy tại: https://fal.ai/dashboard/keys
FAL_API_KEY=

# ===== FACEBOOK =====
# App ID & Secret lấy tại https://developers.facebook.com/apps
FB_APP_ID=
FB_APP_SECRET=
# Page Access Token của 2 Fanpage (sẽ điền ở UI Settings sau khi đăng nhập)

# ===== OTA DATABASE (Google Cloud SQL - READ ONLY) =====
OTA_DB_HOST=35.198.242.104
OTA_DB_PORT=5432
OTA_DB_NAME=sonder
OTA_DB_USER=postgres
OTA_DB_PASSWORD=
OTA_DB_SSL=false

# ===== VNPay =====
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vnapigw.html
VNP_RETURN_URL=http://localhost:3000/api/payment/vnpay-return

# ===== MoMo =====
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:3000/api/payment/momo-return
MOMO_IPN_URL=http://localhost:3000/api/payment/momo-ipn

# ===== Email (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=VP Marketing <noreply@sondervn.com>
